nfidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "DOMAIN.md", "source_location": "photo hard rule 1: byte-ceiling reuses the quality search", "weight": 1.0}, {"source": "domain_hard_rules", "target": "domain_effectivedpi", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "DOMAIN.md", "source_location": "rule 3", "weight": 1.0}, {"source": "domain_hard_rules", "target": "domain_qualityfloor", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "DOMAIN.md", "source_location": "rule 4", "weight": 1.0}, {"source": "domain_hard_rules", "target": "docs_prd_n2_agpl_quarantine", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "DOMAIN.md", "source_location": "rule 5: AGPL deps isolated to adapter modules", "weight": 1.0}, {"source": "docs_prd_n2_agpl_quarantine", "target": "domain_pikepdf_engine", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "DOMAIN.md", "source_location": "Why pikepdf is default: AGPL \u00a713 network copyleft", "weight": 1.0}], "hyperedges": [{"id": "target_size_pipeline", "label": "Target-Size Compression Pipeline", "nodes": ["domain_target_size_algorithm", "domain_targetsizesearch", "domain_budgetdecomposition", "domain_bytebudget", "domain_qualityfloor", "domain_effectivedpi"], "relation": "participate_in", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "DOMAIN.md"}]}